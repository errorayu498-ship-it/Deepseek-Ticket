<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Templates • <%= botName %></title>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <style>:root{--bg:#0a0a0a;--card:#111;--border:#222;--red:#FF0000;--text:#fff;--sec:#999;--muted:#666;--input:#0f0f0f}*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Rajdhani',sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh}.sidebar{width:260px;background:#0f0f0f;border-right:1px solid var(--border);padding:30px 0;position:fixed;height:100vh}.sidebar-head{padding:0 25px 30px;border-bottom:1px solid var(--border);text-align:center}.sidebar-icon{font-size:40px}.sidebar-title{color:var(--red);font-size:20px;font-weight:700;letter-spacing:3px}.nav{padding:20px 15px}.nav a{display:flex;align-items:center;padding:14px 20px;color:var(--sec);text-decoration:none;border-radius:8px;margin-bottom:5px;transition:.3s;font-weight:600;letter-spacing:1px}.nav a:hover,.nav a.active{background:rgba(255,0,0,0.1);color:var(--red)}.main{margin-left:260px;padding:40px;flex:1}.head{display:flex;justify-content:space-between;align-items:center;margin-bottom:35px}.head h1{font-size:36px;letter-spacing:2px}.head h1 span{color:var(--red)}.btn{padding:12px 28px;border:none;border-radius:8px;font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:700;letter-spacing:2px;cursor:pointer;transition:.3s;text-decoration:none;display:inline-flex;align-items:center;gap:8px}.btn-red{background:linear-gradient(135deg,var(--red),#CC0000);color:#fff}.btn-red:hover{box-shadow:0 8px 25px rgba(255,0,0,0.3);transform:translateY(-2px)}.btn-out{background:transparent;border:1px solid var(--red);color:var(--red)}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(350px,1fr));gap:25px}.tcard{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:25px;transition:.3s;position:relative}.tcard:hover{border-color:var(--red);transform:translateY(-3px)}.tcard.premium::before{content:'DEFAULT';position:absolute;top:15px;right:15px;background:rgba(255,0,0,0.2);color:var(--red);padding:4px 12px;border-radius:4px;font-size:10px;font-weight:700;letter-spacing:2px}.preview{background:#1a1a1a;border-radius:8px;padding:15px;margin-bottom:15px;border-left:3px solid var(--red)}.preview h4{color:var(--red);font-size:16px;margin-bottom:5px}.preview p{color:var(--sec);font-size:13px}.tcard h3{font-size:20px;letter-spacing:2px}.tcard>p{color:var(--muted);font-size:13px;margin:8px 0 15px}.actions{display:flex;gap:8px;flex-wrap:wrap}.actions .btn{font-size:13px;padding:8px 16px}.badge{color:var(--muted);font-size:11px;letter-spacing:1px;margin-top:12px}</style>
</head>
<body>
    <aside class="sidebar"><div class="sidebar-head"><span class="sidebar-icon">🎫</span><h2 class="sidebar-title"><%= botName %></h2></div><nav class="nav"><a href="/">🏠 Dashboard</a><a href="/templates" class="active">📁 Templates</a><a href="/logout">🚪 Logout</a></nav></aside>
    <main class="main">
        <div class="head"><h1>📁 <span>Templates</span></h1><a href="/templates/create" class="btn btn-red">+ New Template</a></div>
        <div class="grid">
            <% templates.forEach(t => { %>
                <div class="tcard <%= t.isDefault ? 'premium' : '' %>">
                    <div class="preview"><h4><%= t.embed?.title || 'Ticket System' %></h4><p><%= (t.embed?.description || '').substring(0, 100) %>...</p></div>
                    <h3><%= t.name %></h3><p><%= t.description || 'No description' %></p>
                    <div class="actions"><a href="/templates/<%= t._id %>/edit" class="btn btn-out">✏️ Edit</a><button onclick="dup('<%= t._id %>')" class="btn btn-out">📋 Copy</button><button onclick="del('<%= t._id %>')" class="btn btn-out" style="border-color:#333;color:#999">🗑️</button></div>
                    <p class="badge">Used: <%= t.usageCount %> times • <%= new Date(t.createdAt).toLocaleDateString() %></p>
                </div>
            <% }) %>
        </div>
    </main>
    <script>
        async function del(id){if(!confirm('Delete?'))return;await fetch(`/templates/${id}/delete`,{method:'POST'});location.reload()}
        async function dup(id){await fetch(`/templates/${id}/duplicate`,{method:'POST'});location.reload()}
    </script>
</body>
</html>
